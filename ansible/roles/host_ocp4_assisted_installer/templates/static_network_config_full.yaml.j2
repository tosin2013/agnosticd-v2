{% for index in range(0, control_plane_instance_count | int) %} 
{% set control_plane_loop = loop %}
- network_yaml: |
    interfaces:
    - ipv4:
        dhcp: true
        enabled: true
      name: enp1s0
      state: up
      type: ethernet
    - ipv4:
        address:
        - ip: {{ ai_network_prefix }}.1{{ index }}
          prefix-length: {{ ai_network_prefix_length }}
        dhcp: false
        enabled: true
      name: enp2s0
      state: up
      type: ethernet
    routes:
      config:
      - destination: 0.0.0.0/0
        next-hop-address: {{ ai_network_prefix }}.1
        next-hop-interface: enp2s0
        metric: 200
  mac_interface_map:
    - mac_address: "{{ ai_control_plane_macs[index] }}"
      logical_nic_name: "enp1s0"
    - mac_address: "{{ ai_control_plane_macs2[index] }}"
      logical_nic_name: "enp2s0"
{% endfor %}
{% for index in range(0, worker_instance_count | int) %}
{% set worker_loop = loop %}
- network_yaml: |
    interfaces:
    - ipv4:
        dhcp: true
        enabled: true
      name: enp1s0
      state: up
      type: ethernet
    - ipv4:
        address:
        - ip: {{ ai_network_prefix }}.2{{ index }}
          prefix-length: {{ ai_network_prefix_length }}
        dhcp: false
        enabled: true
      name: enp2s0
      state: up
      type: ethernet
    routes:
      config:
      - destination: 0.0.0.0/0
        next-hop-address: {{ ai_network_prefix }}.1
        next-hop-interface: enp2s0
        metric: 200
  mac_interface_map:
    - mac_address: "{{ ai_workers_macs[index] }}" 
      logical_nic_name: "enp1s0"
    - mac_address: "{{ ai_workers_macs2[index] }}"
      logical_nic_name: "enp2s0"
{% endfor %}
